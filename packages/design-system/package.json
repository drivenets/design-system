{
	"name": "@drivenets/design-system",
	"version": "0.12.1",
	"license": "Apache-2.0",
	"type": "module",
	"types": "./dist/index.d.cts",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./index.min.css": "./dist/index.min.css",
		"./raw-styles/*": "./src/styles/*"
	},
	"files": [
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"./dist",
		"./src",
		"!**/__tests__",
		"!./src/**/*.d.ts",
		"!**/stories",
		"!**/*.stories.*"
	],
	"repository": {
		"url": "https://github.com/drivenets/design-system",
		"directory": "/packages/design-system"
	},
	"scripts": {
		"start": "storybook dev -p 6006",
		"install:playwright": "pnpm exec playwright install chromium --with-deps",
		"lint": "pnpm generate-scss-dts && eslint --max-warnings=0 ${ESLINT_ARGS-} .; EXIT_CODE=$?; rm -rf .scss-dts; exit $EXIT_CODE",
		"//": "ESLINT_ARGS is used to pass arguments to eslint. We're using it so we don't need to duplicate the lint script.",
		"lint:fix": "ESLINT_ARGS=--fix pnpm lint",
		"lint:build": "publint && attw --pack",
		"typecheck": "pnpm generate-scss-dts && tsgo; EXIT_CODE=$?; rm -rf .scss-dts; exit $EXIT_CODE",
		"generate-scss-dts": "typed-scss-modules ./src -o ./.scss-dts --nameFormat all --exportType default > /dev/null 2>&1",
		"test": "vitest --project=\"!requires-build\"",
		"test:coverage": "pnpm test --coverage",
		"test:unit": "vitest --project=unit",
		"test:browser": "vitest --project=browser",
		"test:requires-build": "vitest --project=requires-build",
		"build": "tsdown",
		"build:watch": "pnpm build --watch",
		"build:storybook": "storybook build"
	},
	"dependencies": {
		"@ark-ui/react": "^5.36.1",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.24",
		"@zag-js/react": "^1.40.0",
		"@zag-js/steps": "^1.40.0",
		"classnames": "^2.5.1",
		"csstype": "^3.2.3"
	},
	"peerDependencies": {
		"@internationalized/date": "^3.0.0",
		"@tanstack/react-router": "^1.0.0",
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "catalog:",
		"@drivenets/eslint-plugin-internal": "workspace:*",
		"@drivenets/vite-plugin-design-system": "workspace:*",
		"@eslint/compat": "^2.1.0",
		"@faker-js/faker": "^10.3.0",
		"@hookform/resolvers": "^5.4.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/react-vite": "^10.4.1",
		"@tanstack/react-query": "^5.100.14",
		"@tanstack/react-router": "^1.170.8",
		"@tsdown/css": "^0.22.0",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "catalog:",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser-playwright": "^4.1.7",
		"@vitest/coverage-v8": "catalog:",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "catalog:",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-storybook": "^10.4.1",
		"mockdate": "^3.0.5",
		"playwright": "^1.60.0",
		"publint": "catalog:",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-hook-form": "^7.76.1",
		"remark-gfm": "^4.0.1",
		"sass-embedded": "^1.100.0",
		"storybook": "^10.4.1",
		"tsdown": "catalog:",
		"typed-scss-modules": "^8.1.1",
		"typescript": "catalog:",
		"typescript-plugin-css-modules": "^5.2.0",
		"vite": "8.0.14",
		"vitest": "catalog:",
		"vitest-browser-react": "^2.1.0",
		"zod": "^4.4.3"
	}
}
